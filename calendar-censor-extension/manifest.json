{
  "manifest_version": 3,
  "name": "Google Calendar Title Censor",
  "version": "1.0.0",
  "description": "Toggle solid censor bars over Google Calendar event titles in the current tab.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://calendar.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Calendar title censor"
  },
  "content_scripts": [
    {
      "matches": [
        "https://calendar.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
